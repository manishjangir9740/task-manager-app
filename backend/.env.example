# ======================================================
# backend/.env.example
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to git!
# ======================================================

PORT=5000

# --- MySQL Database ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=task_manager_db
DB_PORT=3306
DB_SSL=false
DB_CONNECTION_LIMIT=10

# Alternatively, use a full connection string (takes priority over above vars):
# DATABASE_URL=mysql://user:password@host:3306/task_manager_db

# --- JWT ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# --- CORS ---
# Only needed if frontend is on a DIFFERENT domain than the backend.
# Same-domain deployments (nginx proxy): leave this empty.
# Separate domains (e.g. Vercel frontend + Railway backend):
#   FRONTEND_URL=https://your-app.vercel.app
# Multiple origins (comma-separated):
#   FRONTEND_URL=https://app.example.com,https://www.example.com
FRONTEND_URL=http://localhost:5173
