# ======================================================
# frontend/.env.example
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to git!
# ======================================================

# VITE_API_URL: Only set this if frontend and backend are on DIFFERENT domains.
#
# LOCAL DEV:
#   Leave empty. Vite dev server (vite.config.ts) proxies /api/* to localhost:5000.
#
# PRODUCTION - same domain (nginx serves both):
#   Leave empty. /api/* resolves to same origin automatically.
#
# PRODUCTION - separate domains (e.g. Vercel frontend + Railway/Render backend):
#   VITE_API_URL=https://your-backend.railway.app
#
VITE_API_URL=
